{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schemaVersion": 1,
  "artifact": "shared",
  "title": "Bug Hunter Shared Definitions",
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },
    "category": {
      "type": "string",
      "enum": [
        "logic",
        "security",
        "error-handling",
        "concurrency",
        "edge-case",
        "data-integrity",
        "type-safety",
        "resource-leak",
        "api-contract",
        "cross-file"
      ]
    },
    "stride": {
      "type": "string",
      "enum": [
        "Spoofing",
        "Tampering",
        "Repudiation",
        "InfoDisclosure",
        "DoS",
        "ElevationOfPrivilege",
        "N/A"
      ]
    },
    "verificationMode": {
      "type": "string",
      "enum": ["INDEPENDENTLY_VERIFIED", "EVIDENCE_BASED"]
    },
    "confidenceLabel": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "coverageStatus": {
      "type": "string",
      "enum": ["pending", "in_progress", "done", "failed"]
    }
  }
}
