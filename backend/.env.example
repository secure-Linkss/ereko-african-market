# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ereko:ereko_password@localhost:5432/ereko_db

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Or use full URL:
# REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_strong_random_secret_for_access_tokens
JWT_REFRESH_SECRET=CHANGE_ME_strong_random_secret_for_refresh_tokens
JWT_MFA_SECRET=CHANGE_ME_strong_random_secret_for_mfa_tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_MFA_EXPIRES_IN=10m

# ─── STRIPE ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# ─── CLOUDINARY ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your_postmark_api_key
SMTP_PASS=your_postmark_api_key
EMAIL_FROM=noreply@ereko.market
EMAIL_FROM_NAME=EREKO Market

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://ereko.market
FRONTEND_URL=http://localhost:3000

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── LOYALTY PROGRAM ──────────────────────────────────────────────────────────
LOYALTY_POINTS_PER_POUND=10
LOYALTY_POINT_VALUE_PENCE=1
LOYALTY_FAMILY_THRESHOLD=500
LOYALTY_ELDER_THRESHOLD=2000
LOYALTY_ROYALTY_THRESHOLD=5000

# ─── BUSINESS RULES ───────────────────────────────────────────────────────────
FREE_SHIPPING_THRESHOLD_MINOR=5500
